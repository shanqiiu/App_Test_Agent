# App_Test_Agent 环境配置模板
# 复制此文件为 .env 并填入实际值

# ==================== VLM API 配置（必需）====================

# VLM API Key（用于 UI 分析、语义理解、风格提取）
# 支持 OpenAI 兼容接口
VLM_API_KEY=your-vlm-api-key-here

# VLM API 端点
VLM_API_URL=https://api.openai-next.com/v1/chat/completions

# VLM 模型名称
VLM_MODEL=gpt-4o

# ==================== DashScope API 配置（可选）====================

# DashScope API Key（用于 AI 图像生成）
# 用于：异常弹窗生成、区域加载图标生成
DASHSCOPE_API_KEY=your-dashscope-key-here

# 图像生成后端：dashscope / local / auto
# 建议本地开发环境使用 dashscope；auto 表示优先本地服务，未配置时回退到 DashScope
IMAGE_GEN_BACKEND=dashscope

# DashScope 图像生成模型（纯文生图）
DASHSCOPE_IMAGE_GEN_MODEL=qwen-image-max

# DashScope 图像编辑模型（带参考图编辑）
DASHSCOPE_IMAGE_EDIT_MODEL=qwen-image-edit-max

# 本地文生图服务（可选，配置后优先于 DashScope）
# 示例: http://10.85.177.2:8042/generate
LOCAL_IMAGE_API_URL=
# 本地文生图步数（可选）
LOCAL_IMAGE_API_STEPS=9
# 本地文生图超时秒数（可选）
LOCAL_IMAGE_API_TIMEOUT=120
# 本地文生图随机种子（可选，留空表示不传）
LOCAL_IMAGE_API_SEED=
# DashScope 基础 URL（可选，默认官方地址）
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/api/v1

# ==================== 模型配置 ====================

# 结构提取模型（用于 Stage 2 语义过滤）
STRUCTURE_MODEL=qwen-vl-max

# VL 模型（视觉语言模型，img2text2html2img 项目使用）
VL_MODEL=qwen-vl-max

# LLM 模型（用于 HTML 生成，img2text2html2img 项目使用）
LLM_MODEL=qwen3-235b-a22b

# ==================== OmniParser 配置 ====================

# 推理设备：cuda 或 cpu
OMNIPARSER_DEVICE=cuda

# 模型路径（可选，默认自动下载）
# OMNIPARSER_MODEL_PATH=/path/to/models

# ==================== 代理配置（如需）====================

# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ==================== 项目说明 ====================
#
# 1. img2text2html2img 项目：
#    - 需要: VL_MODEL, LLM_MODEL
#    - API: 使用 --api-key 参数传入
#
# 2. ui_semantic_patch 项目：
#    - 必需: VLM_API_KEY, DASHSCOPE_API_KEY
#    - 常用: IMAGE_GEN_BACKEND, DASHSCOPE_IMAGE_GEN_MODEL, DASHSCOPE_IMAGE_EDIT_MODEL
#    - 可选: LOCAL_IMAGE_API_*, STRUCTURE_MODEL, VLM_MODEL, OMNIPARSER_DEVICE
#
