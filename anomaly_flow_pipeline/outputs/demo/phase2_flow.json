{
  "id": "shopping",
  "name": "购物类APP",
  "description": "以商品浏览、搜索、下单、支付、售后为核心流程的电商类应用",
  "representatives": [
    "淘宝",
    "京东",
    "拼多多"
  ],
  "coreDomains": [
    "商品",
    "搜索",
    "购物车",
    "订单",
    "支付",
    "物流",
    "营销",
    "用户"
  ],
  "events": [
    {
      "id": "keyword_search",
      "name": "关键词搜索",
      "category": "search",
      "description": "用户输入关键词搜索商品",
      "triggerType": "input",
      "targetPage": "search",
      "relatedData": [
        "keyword"
      ]
    },
    {
      "id": "search_suggestion_click",
      "name": "搜索联想词点击",
      "category": "search",
      "description": "用户点击搜索联想词",
      "triggerType": "click",
      "targetPage": "search",
      "relatedData": [
        "suggestion"
      ]
    },
    {
      "id": "add_filter",
      "name": "添加筛选条件",
      "category": "filter_sort",
      "description": "用户选择筛选条件",
      "triggerType": "click",
      "targetPage": "searchResult",
      "relatedData": [
        "filterType",
        "filterValue"
      ]
    },
    {
      "id": "change_sort",
      "name": "切换排序方式",
      "category": "filter_sort",
      "description": "用户切换排序规则",
      "triggerType": "click",
      "targetPage": "searchResult",
      "relatedData": [
        "sortType"
      ]
    },
    {
      "id": "click_product_card",
      "name": "点击商品卡片",
      "category": "product_browse",
      "description": "用户点击商品卡片进入详情",
      "triggerType": "click",
      "targetPage": "searchResult",
      "relatedData": [
        "productId"
      ]
    },
    {
      "id": "swipe_image_carousel",
      "name": "轮播图滑动",
      "category": "product_browse",
      "description": "用户滑动商品图片轮播",
      "triggerType": "swipe",
      "targetPage": "productDetail"
    },
    {
      "id": "select_sku",
      "name": "选择商品规格",
      "category": "product_browse",
      "description": "用户选择SKU规格",
      "triggerType": "click",
      "targetPage": "productDetail",
      "relatedData": [
        "skuAttributes"
      ]
    },
    {
      "id": "add_to_cart",
      "name": "加入购物车",
      "category": "cart",
      "description": "用户将商品加入购物车",
      "triggerType": "click",
      "targetPage": "productDetail",
      "relatedData": [
        "productId",
        "skuId"
      ]
    },
    {
      "id": "view_cart",
      "name": "查看购物车",
      "category": "cart",
      "description": "用户进入购物车页面",
      "triggerType": "click",
      "targetPage": "cart"
    },
    {
      "id": "select_address",
      "name": "选择收货地址",
      "category": "checkout_payment",
      "description": "用户选择收货地址",
      "triggerType": "click",
      "targetPage": "checkout",
      "relatedData": [
        "addressId"
      ]
    },
    {
      "id": "select_coupon",
      "name": "选择优惠券",
      "category": "checkout_payment",
      "description": "用户选择优惠券",
      "triggerType": "click",
      "targetPage": "checkout",
      "relatedData": [
        "couponId"
      ]
    },
    {
      "id": "submit_order",
      "name": "提交订单",
      "category": "checkout_payment",
      "description": "用户提交订单",
      "triggerType": "click",
      "targetPage": "checkout",
      "relatedData": [
        "orderId"
      ]
    },
    {
      "id": "confirm_payment",
      "name": "确认支付",
      "category": "checkout_payment",
      "description": "用户确认支付",
      "triggerType": "click",
      "targetPage": "payment",
      "relatedData": [
        "orderId"
      ]
    },
    {
      "id": "view_order_detail",
      "name": "查看订单详情",
      "category": "order_management",
      "description": "用户查看订单详情",
      "triggerType": "click",
      "targetPage": "orderDetail",
      "relatedData": [
        "orderId"
      ]
    }
  ],
  "topics": [
    {
      "id": "digital",
      "name": "数码3C",
      "description": "手机、电脑、平板、耳机等数码产品",
      "applicableAppTypes": [
        "shopping"
      ],
      "fields": [
        {
          "id": "brand",
          "name": "品牌",
          "type": "string",
          "filterable": true,
          "displayInCard": true,
          "example": "Apple"
        },
        {
          "id": "price",
          "name": "价格",
          "type": "price",
          "filterable": true,
          "sortable": true,
          "displayInCard": true,
          "unit": "元",
          "example": 6999
        },
        {
          "id": "model",
          "name": "型号",
          "type": "string",
          "displayInDetail": true,
          "example": "iPhone 16 Pro"
        },
        {
          "id": "storage",
          "name": "存储容量",
          "type": "enum",
          "filterable": true,
          "displayInDetail": true,
          "enumValues": [
            "128GB",
            "256GB",
            "512GB",
            "1TB"
          ],
          "example": "256GB"
        },
        {
          "id": "color",
          "name": "颜色",
          "type": "enum",
          "filterable": true,
          "displayInCard": true,
          "enumValues": [
            "沙漠钛金属",
            "白色钛金属",
            "黑色钛金属"
          ],
          "example": "沙漠钛金属"
        },
        {
          "id": "processor",
          "name": "处理器",
          "type": "string",
          "displayInDetail": true,
          "example": "A18 Pro"
        },
        {
          "id": "rating",
          "name": "评分",
          "type": "number",
          "sortable": true,
          "displayInCard": true,
          "example": 4.8
        },
        {
          "id": "salesVolume",
          "name": "销量",
          "type": "number",
          "sortable": true,
          "displayInCard": true,
          "example": 58000
        },
        {
          "id": "productId",
          "name": "商品ID",
          "type": "string",
          "required": true,
          "example": "product-digital-001"
        },
        {
          "id": "skuId",
          "name": "SKU ID",
          "type": "string",
          "required": true,
          "example": "sku-digital-001-256gb-desert"
        },
        {
          "id": "orderId",
          "name": "订单ID",
          "type": "string",
          "example": "order-demo-001"
        },
        {
          "id": "addressId",
          "name": "收货地址ID",
          "type": "string",
          "example": "address-demo-001"
        },
        {
          "id": "couponId",
          "name": "优惠券ID",
          "type": "string",
          "example": "coupon-demo-001"
        },
        {
          "id": "subsidyPrice",
          "name": "补贴后价格",
          "type": "price",
          "displayInDetail": true,
          "unit": "元",
          "example": 1400.8
        },
        {
          "id": "subsidyAmount",
          "name": "补贴金额",
          "type": "price",
          "displayInDetail": true,
          "unit": "元",
          "example": 109.65
        },
        {
          "id": "maxPrice",
          "name": "价格上限",
          "type": "price",
          "filterable": true,
          "unit": "元",
          "example": 3000
        },
        {
          "id": "promotionTag",
          "name": "促销标签",
          "type": "string",
          "filterable": true,
          "displayInCard": true,
          "example": "百亿补贴"
        },
        {
          "id": "quantity",
          "name": "购买数量",
          "type": "number",
          "displayInDetail": true,
          "example": 1
        },
        {
          "id": "deliveryMethod",
          "name": "配送方式",
          "type": "string",
          "displayInDetail": true,
          "example": "京东快递"
        },
        {
          "id": "deliveryTime",
          "name": "配送时间",
          "type": "string",
          "displayInDetail": true,
          "example": "后天（周日）09:00-21:00"
        },
        {
          "id": "address",
          "name": "收货地址",
          "type": "string",
          "displayInDetail": true,
          "example": "默认地址"
        }
      ],
      "mockInstances": [
        {
          "instanceId": "huawei_changxiang_70x",
          "imageUrl": null,
          "values": {
            "brand": "华为",
            "price": 1400.8,
            "model": "畅享70X",
            "storage": "256GB",
            "color": null,
            "processor": null,
            "rating": null,
            "salesVolume": null,
            "productId": null,
            "skuId": null,
            "orderId": null,
            "addressId": null,
            "couponId": null,
            "subsidyPrice": null,
            "subsidyAmount": null,
            "maxPrice": 3000,
            "promotionTag": "百亿补贴",
            "quantity": 1,
            "deliveryMethod": null,
            "deliveryTime": null,
            "address": null
          }
        }
      ]
    }
  ],
  "ui": {
    "layouts": [
      {
        "id": "tab-split",
        "name": "Tab分栏布局",
        "description": "顶部Tab栏切换不同内容区域",
        "applicablePages": [
          "首页",
          "搜索结果"
        ],
        "characteristics": {
          "columnCount": 2
        }
      },
      {
        "id": "dual-waterfall",
        "name": "双列瀑布流",
        "description": "两列交错排列商品卡片",
        "applicablePages": [
          "搜索结果",
          "推荐商品流"
        ],
        "characteristics": {
          "columnCount": 2
        }
      },
      {
        "id": "single-column",
        "name": "单列流式",
        "description": "内容单列纵向排列",
        "applicablePages": [
          "商品详情",
          "结算页",
          "订单详情"
        ]
      },
      {
        "id": "bottom-sheet",
        "name": "底部抽屉",
        "description": "底部弹出规格选择/筛选面板",
        "applicablePages": [
          "SKU选择",
          "筛选面板"
        ]
      },
      {
        "id": "grid-matrix",
        "name": "网格矩阵",
        "description": "多列等宽网格排列",
        "applicablePages": [
          "快捷入口",
          "分类入口"
        ]
      }
    ],
    "components": [
      {
        "id": "SearchBar",
        "name": "搜索栏",
        "description": "带搜索图标的输入栏",
        "category": "表单",
        "arkTS": "Search()"
      },
      {
        "id": "Carousel",
        "name": "轮播图",
        "description": "商品图片轮播",
        "category": "展示",
        "arkTS": "Swiper()"
      },
      {
        "id": "ProductCard",
        "name": "商品卡片",
        "description": "商品信息展示卡片",
        "category": "业务",
        "arkTS": "Column() + Image() + Text()"
      },
      {
        "id": "Price",
        "name": "价格组件",
        "description": "价格展示（带原价划线）",
        "category": "展示",
        "arkTS": "Row() + Text()"
      },
      {
        "id": "Tag",
        "name": "标签",
        "description": "商品标签（自营/包邮等）",
        "category": "展示",
        "arkTS": "Text() + backgroundColor"
      },
      {
        "id": "FilterBar",
        "name": "筛选栏",
        "description": "筛选条件操作栏",
        "category": "业务",
        "arkTS": "Row() + Button()"
      },
      {
        "id": "SortBar",
        "name": "排序栏",
        "description": "排序方式切换栏",
        "category": "业务",
        "arkTS": "Row() + Button()"
      },
      {
        "id": "CartItem",
        "name": "购物车项",
        "description": "购物车商品项",
        "category": "业务",
        "arkTS": "Row() + Checkbox() + Stepper()"
      },
      {
        "id": "Stepper",
        "name": "步进器",
        "description": "数量增减组件",
        "category": "表单",
        "arkTS": "Stepper()"
      },
      {
        "id": "Checkbox",
        "name": "复选框",
        "description": "多选组件",
        "category": "表单",
        "arkTS": "Checkbox()"
      },
      {
        "id": "CouponCard",
        "name": "优惠券卡片",
        "description": "优惠券展示组件",
        "category": "业务",
        "arkTS": "Row() + Column()"
      },
      {
        "id": "AddressCard",
        "name": "地址卡片",
        "description": "收货地址展示",
        "category": "业务",
        "arkTS": "Row() + Column()"
      },
      {
        "id": "OrderCard",
        "name": "订单卡片",
        "description": "订单信息卡片",
        "category": "业务",
        "arkTS": "Column() + Card()"
      },
      {
        "id": "Button",
        "name": "按钮",
        "description": "可点击操作按钮",
        "category": "基础",
        "arkTS": "Button()"
      },
      {
        "id": "Badge",
        "name": "徽标",
        "description": "购物车角标",
        "category": "基础",
        "arkTS": "Badge()"
      }
    ],
    "navigation": [
      {
        "id": "bottom-tab",
        "name": "底部Tab导航",
        "description": "底部4个Tab切换主功能区",
        "typicalTabs": [
          "首页",
          "分类",
          "购物车",
          "我的"
        ],
        "arkTSImplementation": "Tabs({ barPosition: BarPosition.End })"
      }
    ],
    "interactions": [
      {
        "id": "tap",
        "name": "点击",
        "description": "单次点击",
        "gestureType": "TapGesture",
        "feedbackType": "视觉高亮",
        "typicalUsages": [
          "点击商品卡片",
          "点击按钮"
        ]
      },
      {
        "id": "swipe",
        "name": "滑动",
        "description": "快速滑动切换",
        "gestureType": "SwipeGesture",
        "feedbackType": "页面切换动画",
        "typicalUsages": [
          "轮播图切换",
          "Tab切换"
        ]
      },
      {
        "id": "scroll",
        "name": "滚动",
        "description": "垂直滚动浏览",
        "gestureType": "PanGesture",
        "feedbackType": "惯性滚动",
        "typicalUsages": [
          "商品列表滚动"
        ]
      },
      {
        "id": "pull-refresh",
        "name": "下拉刷新",
        "description": "下拉触发刷新",
        "feedbackType": "下拉指示器",
        "typicalUsages": [
          "刷新商品列表"
        ]
      },
      {
        "id": "input",
        "name": "文本输入",
        "description": "输入框输入文字",
        "feedbackType": "光标闪烁",
        "typicalUsages": [
          "搜索关键词输入"
        ]
      }
    ]
  },
  "baselineMapping": {
    "baseline_dir": "apps/baseline/shoppingApp",
    "screenKeys": [
      "home",
      "search",
      "searchResult",
      "productDetail",
      "cart",
      "checkout",
      "payment",
      "orders",
      "orderDetail"
    ]
  },
  "mainFlow": {
    "id": "flow-from-utg",
    "name": "去京东下单一台参百亿补贴的华为手机，价格控制在3000以内",
    "description": "去京东下单一台参百亿补贴的华为手机，价格控制在3000以内",
    "precondition": "用户已登录，京东首页正常加载",
    "steps": [
      {
        "order": 1,
        "action": "Step 1: 页面初始状态：APP首页已加载，顶部搜索框内显示历史搜索词“海尔洗衣机”\n操作：用户清除搜索框旧内容，输入“华为手机”，点击搜索按钮\n最终状态：页面跳转至搜索结果页，展示华为手机商品推荐列表及国家补贴×百亿补贴活动入口"
      },
      {
        "order": 2,
        "action": "Step 2: 页面初始状态：搜索结果页展示华为手机商品推荐列表及国家补贴×百亿补贴活动入口\n操作：用户依次点击页面右侧筛选按钮，在弹出的筛选面板中勾选“百亿补贴”选项并点击底部“确定”按钮、在最高价输入框中输入“3000”后点击底部“确定”按钮、点击屏幕中央的“网络连接失败”提示条触发网络重试、等待AI助手询问目标商品型号、点击列表中目标商品（华为畅享70X 256GB）的列表项\n最终状态：页面跳转至商品详情页，展示商品高清大图、详细规格（256GB/雪域白）、实时价格（1400.8元）及右侧加购按钮"
      },
      {
        "order": 3,
        "action": "Step 3: 页面初始状态：商品详情页展示华为畅享70X 256GB雪域白手机详情，右侧可见加购按钮\n操作：用户点击商品详情页右侧的加号按钮\n最终状态：商品成功加入购物车，页面跳转至订单确认与结算界面"
      },
      {
        "order": 4,
        "action": "Step 6: 页面初始状态：APP首页展示搜索框（内容为“华为手机”）及右侧搜索按钮，主体呈现推荐搜索内容列表\n操作：用户点击底部导航栏的购物车按钮\n最终状态：页面跳转至购物车页面，展示已添加的商品清单与结算入口"
      },
      {
        "order": 5,
        "action": "Step 7: 页面初始状态：购物车页面展示已添加的华为畅享70X商品清单与底部结算入口\n操作：用户点击底部红色的“去结算（1）”按钮\n最终状态：页面跳转至结算页，展示已选商品（数量1件）及总金额1400.8元"
      },
      {
        "order": 6,
        "action": "Step 8: 页面初始状态：结算页展示已选的华为畅享70X 256GB雪域白手机（数量1件）及总金额1400.8元\n操作：用户依次核对订单信息并确认无误、点击底部“提交订单1400.8元”按钮\n最终状态：系统弹出支付确认提示框，展示多种支付方式供用户选择，流程进入支付决策环节"
      }
    ]
  }
}