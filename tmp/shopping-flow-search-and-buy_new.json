{
  "id": "shopping",
  "name": "购物类APP",
  "description": "以商品浏览、搜索、下单、支付、售后为核心流程的电商类应用",
  "representatives": ["淘宝", "京东", "拼多多"],
  "coreDomains": ["商品", "搜索", "购物车", "订单", "支付", "物流", "营销", "用户"],
  "events": [
    { "id": "keyword_search", "name": "关键词搜索", "category": "search", "description": "用户输入关键词搜索商品", "triggerType": "input", "targetPage": "search", "relatedData": ["keyword"] },
    { "id": "search_suggestion_click", "name": "搜索联想词点击", "category": "search", "description": "用户点击搜索联想词", "triggerType": "click", "targetPage": "search", "relatedData": ["suggestion"] },
    { "id": "add_filter", "name": "添加筛选条件", "category": "filter_sort", "description": "用户选择筛选条件", "triggerType": "click", "targetPage": "searchResult", "relatedData": ["filterType", "filterValue"] },
    { "id": "change_sort", "name": "切换排序方式", "category": "filter_sort", "description": "用户切换排序规则", "triggerType": "click", "targetPage": "searchResult", "relatedData": ["sortType"] },
    { "id": "click_product_card", "name": "点击商品卡片", "category": "product_browse", "description": "用户点击商品卡片进入详情", "triggerType": "click", "targetPage": "searchResult", "relatedData": ["productId"] },
    { "id": "swipe_image_carousel", "name": "轮播图滑动", "category": "product_browse", "description": "用户滑动商品图片轮播", "triggerType": "swipe", "targetPage": "productDetail" },
    { "id": "select_sku", "name": "选择商品规格", "category": "product_browse", "description": "用户选择SKU规格", "triggerType": "click", "targetPage": "productDetail", "relatedData": ["skuAttributes"] },
    { "id": "add_to_cart", "name": "加入购物车", "category": "cart", "description": "用户将商品加入购物车", "triggerType": "click", "targetPage": "productDetail", "relatedData": ["productId", "skuId"] },
    { "id": "view_cart", "name": "查看购物车", "category": "cart", "description": "用户进入购物车页面", "triggerType": "click", "targetPage": "cart" },
    { "id": "select_address", "name": "选择收货地址", "category": "checkout_payment", "description": "用户选择收货地址", "triggerType": "click", "targetPage": "checkout", "relatedData": ["addressId"] },
    { "id": "select_coupon", "name": "选择优惠券", "category": "checkout_payment", "description": "用户选择优惠券", "triggerType": "click", "targetPage": "checkout", "relatedData": ["couponId"] },
    { "id": "submit_order", "name": "提交订单", "category": "checkout_payment", "description": "用户提交订单", "triggerType": "click", "targetPage": "checkout", "relatedData": ["orderId"] },
    { "id": "confirm_payment", "name": "确认支付", "category": "checkout_payment", "description": "用户确认支付", "triggerType": "click", "targetPage": "payment", "relatedData": ["orderId"] },
    { "id": "view_order_detail", "name": "查看订单详情", "category": "order_management", "description": "用户查看订单详情", "triggerType": "click", "targetPage": "orderDetail", "relatedData": ["orderId"] }
  ],
  "topics": [
    {
      "id": "digital",
      "name": "数码3C",
      "description": "手机、电脑、平板、耳机等数码产品",
      "applicableAppTypes": ["shopping"],
      "fields": [
        { "id": "brand", "name": "品牌", "type": "string", "filterable": true, "displayInCard": true, "example": "Apple" },
        { "id": "price", "name": "价格", "type": "price", "filterable": true, "sortable": true, "displayInCard": true, "unit": "元", "example": 6999 },
        { "id": "model", "name": "型号", "type": "string", "displayInDetail": true, "example": "iPhone 16 Pro" },
        { "id": "storage", "name": "存储容量", "type": "enum", "filterable": true, "displayInDetail": true, "enumValues": ["128GB", "256GB", "512GB", "1TB"], "example": "256GB" },
        { "id": "color", "name": "颜色", "type": "enum", "filterable": true, "displayInCard": true, "enumValues": ["沙漠钛金属", "白色钛金属", "黑色钛金属"], "example": "沙漠钛金属" },
        { "id": "processor", "name": "处理器", "type": "string", "displayInDetail": true, "example": "A18 Pro" },
        { "id": "rating", "name": "评分", "type": "number", "sortable": true, "displayInCard": true, "example": 4.8 },
        { "id": "salesVolume", "name": "销量", "type": "number", "sortable": true, "displayInCard": true, "example": 58000 }
