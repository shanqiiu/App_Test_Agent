{
  "version": "1.0",
  "description": "页面类型 → 异常模式映射规则表（通用规则引擎）",
  "page_types": {
    "splash":      {"name": "启动页/开屏页",     "description": "应用启动画面、品牌展示、开屏广告"},
    "home":        {"name": "首页/主页面",       "description": "应用主界面、tab导航页"},
    "search":      {"name": "搜索/筛选页",       "description": "搜索框、筛选条件、日期选择"},
    "list_result": {"name": "列表/结果页",       "description": "商品列表、搜索结果、信息流"},
    "detail":      {"name": "详情展示页",        "description": "商品详情、信息详情"},
    "form":        {"name": "表单填写页",        "description": "输入框、表单填写、信息录入"},
    "payment":     {"name": "支付/确认页",       "description": "支付确认、订单确认"},
    "profile":     {"name": "个人中心/设置",     "description": "我的页面、设置页"},
    "loading_wait":{"name": "加载/等待页",       "description": "加载动画、等待状态"},
    "other":       {"name": "其他/未知页面",     "description": "无法明确分类的页面"}
  },
  "rules": [
    {
      "id": "splash_dialog_ad",
      "page_types": ["splash", "home"],
      "anomaly_mode": "dialog",
      "fault_mode": "开屏广告弹窗",
      "instruction_template": "在首页生成广告弹窗遮挡功能入口",
      "priority": 80,
      "gt_category": "dialog",
      "gt_sample": ""
    },
    {
      "id": "home_dialog_coupon",
      "page_types": ["home"],
      "anomaly_mode": "dialog",
      "fault_mode": "优惠券弹窗",
      "instruction_template": "在页面生成优惠券领取弹窗",
      "priority": 70,
      "gt_category": "dialog",
      "gt_sample": ""
    },
    {
      "id": "home_dialog_permission",
      "page_types": ["home", "splash"],
      "anomaly_mode": "dialog",
      "fault_mode": "权限请求弹窗",
      "instruction_template": "模拟定位权限请求弹窗",
      "priority": 60,
      "gt_category": "dialog",
      "gt_sample": ""
    },
    {
      "id": "search_result_empty",
      "page_types": ["list_result", "search"],
      "anomaly_mode": "modify_text",
      "fault_mode": "无结果状态提示",
      "instruction_template": "将查询结果修改为「未找到相关结果」状态",
      "priority": 90,
      "gt_category": "",
      "gt_sample": ""
    },
    {
      "id": "search_button_disabled",
      "page_types": ["search", "form"],
      "anomaly_mode": "modify_text_ocr",
      "fault_mode": "按钮置灰不可用",
      "instruction_template": "将查询按钮置灰，显示为不可点击状态",
      "priority": 70,
      "gt_category": "",
      "gt_sample": ""
    },
    {
      "id": "list_loading_timeout",
      "page_types": ["list_result", "loading_wait"],
      "anomaly_mode": "area_loading",
      "fault_mode": "列表加载超时",
      "instruction_template": "模拟列表加载超时，显示加载失败提示",
      "priority": 85,
      "gt_category": "",
      "gt_sample": "",
      "user_waiting": true
    },
    {
      "id": "detail_dialog_prompt",
      "page_types": ["detail"],
      "anomaly_mode": "dialog",
      "fault_mode": "系统提示弹窗",
      "instruction_template": "模拟系统提示弹窗（与商品相关）",
      "priority": 60,
      "gt_category": "dialog",
      "gt_sample": ""
    },
    {
      "id": "payment_network_error",
      "page_types": ["payment"],
      "anomaly_mode": "dialog",
      "fault_mode": "支付超时弹窗",
      "instruction_template": "模拟支付超时的系统提示弹窗",
      "priority": 90,
      "gt_category": "dialog",
      "gt_sample": "",
      "user_waiting": true
    },
    {
      "id": "profile_login_prompt",
      "page_types": ["profile"],
      "anomaly_mode": "dialog",
      "fault_mode": "登录提示弹窗",
      "instruction_template": "模拟需要登录的权限弹窗",
      "priority": 65,
      "gt_category": "dialog",
      "gt_sample": ""
    },
    {
      "id": "list_content_duplicate",
      "page_types": ["list_result", "home"],
      "anomaly_mode": "content_duplicate",
      "fault_mode": "内容重复展示",
      "instruction_template": "将列表第一个元素复制，制造内容重复异常",
      "priority": 50,
      "gt_category": "",
      "gt_sample": ""
    }
  ],
  "fallback": {
    "anomaly_mode": "dialog",
    "fault_mode": "通用弹窗",
    "instruction_template": "在页面生成广告弹窗遮挡功能入口",
    "priority": 10,
    "gt_category": "dialog",
    "gt_sample": ""
  }
}
