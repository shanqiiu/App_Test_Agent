        # 构建按钮描述文本
        if len(buttons) > 1:
            buttons_desc = ' and '.join([f'"{b}"' for b in buttons])
            buttons_prompt_part = f' Buttons at bottom (side by side): {buttons_desc}.'
        elif buttons:
