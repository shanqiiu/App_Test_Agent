{
  "description": "进入(去哪儿旅行)预订从{origin}到{destination}的机票，出发日期为{departure_date}",
  "app_name": "去哪儿旅行",
  "preconditions": [
    "App已安装",
    "用户已登录",
    "网络可用"
  ],
  "parameters": {
    "origin": {
      "type": "city",
      "required": true,
      "example": "南京"
    },
    "destination": {
      "type": "city",
      "required": true,
      "example": "三亚"
    },
    "departure_date": {
      "type": "date",
      "required": true,
      "example": "2026-03-03"
    }
  },
  "element_mapping": {
    "机票入口": {
      "selector": "xpath=//TextView[@text='机票']",
      "timeout": 5000
    },
    "出发城市": {
      "selector": "xpath=//EditText[@text='出发城市']",
      "timeout": 5000
    },
    "到达城市": {
      "selector": "xpath=//EditText[@text='到达城市']",
      "timeout": 5000
    },
    "日期选择": {
      "selector": "xpath=//TextView[@text='出发日期']",
      "timeout": 5000
    },
    "搜索航班": {
      "selector": "xpath=//Button[@text='搜索']",
      "timeout": 5000
    }
  },
  "error_recovery": {
    "无航班结果": "回退到日期选择步骤，提示用户扩大日期范围",
    "支付超时": "保留订单草稿，支持30分钟内续付",
    "价格变动": "提示用户价格已更新，确认后继续"
  }
}