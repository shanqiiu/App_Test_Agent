    {
      "step": 7,
      "name": "确认订单",
      "description": "确认航班信息、乘客信息、价格明细",
      "key_elements": ["航班摘要", "乘客列表", "价格明细", "保险选项", "优惠券入口", "总价", "提交订单按钮"]
