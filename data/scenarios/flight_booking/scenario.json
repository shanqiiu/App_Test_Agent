      "key_elements": ["航班卡片列表", "航空公司logo", "起飞/降落时间", "票价", "筛选排序栏", "直飞/中转标签"]
    },
    {
      "step": 4,
      "name": "航班详情",
      "description": "点击某个航班查看详情，包含机型、餐食、准点率等",
      "key_elements": ["航班详情卡片", "机型图片", "餐食信息", "行李额度", "准点率", "舱位价格列表", "预订按钮"]
    },
    {
      "step": 5,
      "name": "填写乘客信息",
      "description": "填写乘客姓名、证件号、手机号等信息",
      "key_elements": ["乘客姓名输入框", "证件类型选择", "证件号输入框", "手机号输入框", "常旅客信息", "添加乘客按钮"]
    },
    {
      "step": 6,
      "name": "选座",
      "description": "查看座位图，选择偏好座位",
