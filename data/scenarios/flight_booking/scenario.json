    {
      "step": 8,
      "name": "支付",
      "description": "选择支付方式并完成支付",
      "key_elements": ["支付方式列表", "微信支付", "支付宝", "银行卡", "应付金额", "支付倒计时", "确认支付按钮"]
    }
